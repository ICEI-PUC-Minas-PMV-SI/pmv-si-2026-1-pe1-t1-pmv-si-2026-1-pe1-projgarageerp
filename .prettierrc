{
    "semi": true,
    "trailingComma": "all",
    "singleQuote": false,
    "printWidth": 80,
    "tabWidth": 4,
    "useTabs": false,
    "endOfLine": "auto",

    "overrides": [
        {
            "files": "*.md",
            "options": {
                "proseWrap": "never"
            }
        }
    ]
}
